# Backend configuration. Run the backend from this `backend/` directory; dotenvy
# loads `.env` from the working dir on startup. Copy to `.env` and adjust.
# Relative paths below resolve against `backend/`. Only PARTY_ROOT is required.

# Root of the Parties/ tree — each immediate subdirectory is one party.
# Quote the value if the path contains spaces.
PARTY_ROOT="/path/to/Scene/Parties"

# Checked-in per-party config JSONs (<slug>.json) + the default ruleset.
PARTY_CONFIG_DIR=../parties

# SQLite cache (path index + parsed metadata). Rebuilt on demand.
PARTY_DB_PATH=party.db

# Derived/transcoded-asset cache (images/videos).
PARTY_CACHE_DIR=cache

# Built SPA to serve (Vite `frontend/dist`). With `yarn dev` you don't need this
# — the Vite dev server serves the SPA and proxies /api here.
STATIC_DIR=../frontend/dist

# Shared, UNSCANNED support data spanning all parties (emulator BIOS ROMs, etc.),
# served read-only via /api/support/{file}. Defaults to <PARTY_ROOT>/.support
# (a dot-dir the scanner skips). The Amiga A1200 Kickstart goes here as
# `kick40068.A1200`. Uncomment to override the location.
# PARTY_SUPPORT_DIR=/path/to/shared/support

# Bind address. Use 127.0.0.1 for local dev; 0.0.0.0 behind the edge proxy.
PARTY_BIND=127.0.0.1:3020

# Bypass forward-auth for local dev / LAN-only deploys (do NOT set in prod).
PARTY_OPEN=1

# Transcoder sidecar. Leave unset until the service exists; image/video assets
# are then unavailable (download fallback) but the app still runs.
# PARTY_TRANSCODER_URL=http://127.0.0.1:3021
# PARTY_TRANSCODER_TOKEN=

# Log filter (optional).
# RUST_LOG=info,party_backend=debug
