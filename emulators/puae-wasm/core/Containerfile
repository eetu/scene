# amd64 Debian + emsdk 3.1.74 — the toolchain EmulatorJS pins for its cores.
# We're on arm64 macOS, so this runs under podman's amd64 emulation (the repo's
# sanctioned build env; EmulatorJS warns native ARM won't compile some cores).
# emsdk is baked into a layer so rebuilds don't re-download it.
FROM --platform=linux/amd64 debian:bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      wget curl ca-certificates gpg p7zip-full binutils-mips-linux-gnu \
      build-essential pkgconf python3 git zip xz-utils libsdl2-dev jq \
    && rm -rf /var/lib/apt/lists/*

# Pinned emscripten (matches EmulatorJS/build's build_env.sh).
RUN git clone https://github.com/emscripten-core/emsdk.git /opt/emsdk \
    && cd /opt/emsdk \
    && ./emsdk install 3.1.74 \
    && ./emsdk activate 3.1.74

# Source emsdk on every shell so emcc/emmake are on PATH.
RUN echo 'source /opt/emsdk/emsdk_env.sh >/dev/null 2>&1' >> /etc/bash.bashrc
