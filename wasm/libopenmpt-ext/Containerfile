# amd64 Debian + emsdk 6.0.2 — pinned to current stable (we track the latest
# toolchain, not an old freeze). We're on arm64 macOS, so this runs under
# podman's amd64 emulation. emsdk is baked into a layer so rebuilds don't
# re-download it.
FROM --platform=linux/amd64 debian:bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates python3 build-essential xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Latest stable emscripten.
RUN git clone https://github.com/emscripten-core/emsdk.git /opt/emsdk \
    && cd /opt/emsdk \
    && ./emsdk install 6.0.2 \
    && ./emsdk activate 6.0.2

RUN echo 'source /opt/emsdk/emsdk_env.sh >/dev/null 2>&1' >> /etc/bash.bashrc
