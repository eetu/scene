# Repo-wide Prettier ignore — the single source of truth for the monorepo.
# Prettier only auto-loads the .prettierignore in its CWD, so this root file
# governs the repo-wide `yarn format` / `yarn format:fix` run from the root.

# Dependencies & package-manager internals
**/node_modules/
.yarn/
.pnp.*
yarn.lock
.yarnrc.yml

# Build outputs
**/dist/
**/build/
**/.svelte-kit/
target/

# Vendored third-party code (formatting it would fight upstream + local patches)
**/vendor/

# Hand-authored prose. Prettier trims whitespace inside inline code spans and
# rewrites emphasis/bullet markers, which silently corrupts load-bearing content
# in docs/runbooks (e.g. a `` ` - ` `` filename separator collapsing to `` `-` ``).
# Markdown is left to the author; everything else (code, styles, JSON) is enforced.
*.md

# Local SQLite caches
**/*.db
**/*.db-shm
**/*.db-wal

# Generated emcc/WASM build artifacts (regenerated by build.sh)
emulators/**/core.mjs
emulators/**/core.wasm
**/*.wasm

# Generated JIT post-js bundle (regenerated by core/ejs-jit/bundle.mjs in CI)
emulators/**/ejs-jit/ejs-jit.js

# Custom libopenmpt WASM build: cloned upstream source + emcc artifacts
# (both regenerated by wasm/libopenmpt-ext/build.sh; never hand-formatted).
wasm/**/external/
wasm/**/out/

# Binary test fixtures (real module files for the Playwright playback e2e).
**/testing/fixtures/

# Claude Code agent worktrees — transient checkouts, not repo source.
.claude/

# Generated X-wing geometry (base64 typed arrays baked from data/model.glb by
# scripts/gen-xwing.mjs; regenerated on re-export, never hand-formatted).
packages/player/src/models/xwing.geometry.ts
