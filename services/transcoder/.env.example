# scene-transcoder (Rust ffmpeg sidecar) config — loaded by dotenv on startup.
# All optional; sane loopback defaults. Copy to `.env` to override.

# Bind address. Loopback only — the party backend reaches it over localhost (or
# the LAN in the ../mini deploy).
PARTY_TRANSCODER_HOST=127.0.0.1
PARTY_TRANSCODER_PORT=3021

# Optional shared-secret bearer (defense-in-depth on top of the loopback bind).
# If set, the backend must send the same value as PARTY_TRANSCODER_TOKEN.
# PARTY_TRANSCODER_TOKEN=

# ffmpeg binary (PATH name or absolute). Defaults to `ffmpeg`.
# PARTY_TRANSCODER_FFMPEG=ffmpeg

# Log filter (optional).
# RUST_LOG=info,scene_transcoder=debug
