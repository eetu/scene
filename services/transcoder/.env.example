# Transcoder sidecar config (loaded by dotenv on `party-transcoder` startup).
# All optional. Copy to `.env` if you need to override the loopback defaults.

# Bind address. Loopback only — the backend reaches it over localhost; in the
# ../mini deploy it sits behind Caddy.
PARTY_TRANSCODER_HOST=127.0.0.1
PARTY_TRANSCODER_PORT=3021

# Optional shared-secret bearer (defense-in-depth on top of the loopback bind).
# If set, the backend must send the same value as PARTY_TRANSCODER_TOKEN.
# PARTY_TRANSCODER_TOKEN=

# uvicorn auto-reload (dev only) and log level.
PARTY_TRANSCODER_RELOAD=1
PARTY_TRANSCODER_LOG=info
